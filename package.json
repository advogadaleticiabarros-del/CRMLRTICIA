{
  "name": "crm-juridico",
  "version": "0.1.0",
  "description": "CRM Jurídico — Escritório de Advocacia (gestão de clientes, processos, prazos, financeiro, dashboards e integrações)",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "ts-node src/scripts/migrate.ts",
    "seed:admin": "ts-node src/scripts/seed-admin.ts",
    "seed:admin:prod": "node dist/scripts/seed-admin.js",
    "reconcile:partner-entries": "node dist/scripts/reconcilePartnerEntries.js",
    "fix:aracelia": "ts-node src/scripts/fixAraceliaFolders.ts",
    "deploy:start": "npm run migrate && npm run seed:admin:prod && npm run reconcile:partner-entries && npm start",
    "test": "node --test \"tests/**/*.test.mjs\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "megajs": "^1.3.10",
    "mysql2": "^3.11.3",
    "mysqldump": "^3.2.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
