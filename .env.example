# ─────────────────────────────────────────
# CRM Jurídico — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ─────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3001

# Autenticação
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_AQUI

# ── MySQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_juridico
DB_USER=root
DB_PASSWORD=

# ── Google Calendar ──────────────────────
# Obter em: console.cloud.google.com → APIs → Credenciais
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/google/callback

# ── Telegram Bot ─────────────────────────
# Criar bot: @BotFather no Telegram → /newbot
# Obter chat_id: @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp (preparado — Meta Cloud API) ─
# Configurável também pela tela (Configurações → Notificações → WhatsApp)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT=

# ── Monitoramento Processual (DataJud/CNJ — gratuito) ─
# Provider ativo: datajud | manual | mock | paid_api
PROCESS_PROVIDER=datajud
# Chave PÚBLICA da API DataJud (divulgada pelo CNJ — não é segredo).
# Fonte: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# ── Railway (produção) ───────────────────
# As variáveis acima devem ser definidas no painel do Railway:
# railway.app → seu projeto → Variables
# DB_HOST será fornecido automaticamente pelo plugin MySQL do Railway
