# ─────────────────────────────────────────
# CRM Jurídico — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ─────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3001

# Autenticação
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_AQUI

# ── MySQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_juridico
DB_USER=root
DB_PASSWORD=

# ── Google Calendar ──────────────────────
# Obter em: console.cloud.google.com → APIs → Credenciais
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/google/callback

# ── Telegram Bot ─────────────────────────
# Criar bot: @BotFather no Telegram → /newbot
# Obter chat_id: @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Web Push / VAPID (alertas com o app fechado) ─
# Gerar um par: npx web-push generate-vapid-keys
# Sem estas chaves o push fica inativo (o alerta em 1º plano continua valendo).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@advogadaleticiabarros.com

# ── WhatsApp (preparado — Meta Cloud API) ─
# Configurável também pela tela (Configurações → Notificações → WhatsApp)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT=

# ── Monitoramento Processual (DataJud/CNJ — gratuito) ─
# Provider ativo: datajud | manual | mock | paid_api
PROCESS_PROVIDER=datajud
# Chave PÚBLICA da API DataJud (divulgada pelo CNJ — não é segredo).
# Fonte: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# ── Backup automático para o MEGA (diário 02h) ─
# Login da conta MEGA que vai receber os backups (recomendado: conta dedicada).
MEGA_EMAIL=
MEGA_PASSWORD=
# (Opcional) ID da pasta de destino — o trecho após /fm/ na URL do MEGA.
# Ex.: https://mega.nz/fm/S2p01RSC  →  MEGA_FOLDER_ID=S2p01RSC
# Se vazio, salva na raiz da conta.
MEGA_FOLDER_ID=

# ── E-mail (SMTP) — recuperação de senha, link de proposta, credenciais ─
# Gmail: SMTP_HOST=smtp.gmail.com PORT=587, USER=seu@gmail.com,
#        PASS=Senha de App (myaccount.google.com/apppasswords, exige 2FA).
# Hostinger: SMTP_HOST=smtp.hostinger.com PORT=465 SECURE=true,
#        USER=contato@advogadaleticiabarros.com.br + a senha do e-mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Advocacia Letícia Barros <contato@advogadaleticiabarros.com.br>

# ── Railway (produção) ───────────────────
# As variáveis acima devem ser definidas no painel do Railway:
# railway.app → seu projeto → Variables
# DB_HOST será fornecido automaticamente pelo plugin MySQL do Railway
